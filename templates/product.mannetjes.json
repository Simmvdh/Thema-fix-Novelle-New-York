        "custom_pbwVU8": {
          "type": "custom",
          "settings": {
            "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <style>\n    body {\n      margin: 0;\n      padding: 0;\n    }\n\n    .shipping-bar {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      padding: 6px 16px;\n      background: #f6f6f6;\n      border-radius: 0; /* 👈 hoeken zijn nu niet meer afgerond */\n      margin-top: -14px;\n      font-size: 12px;\n      color: #000;\n    }\n\n    .shipping-bar svg {\n      animation: fade 1s ease-in-out infinite;\n      margin-right: 6px;\n    }\n\n    @keyframes fade {\n      0%, 100% { opacity: 1; }\n      50% { opacity: 0.5; }\n    }\n\n    .left, .right {\n      display: flex;\n      align-items: center;\n      gap: 6px;\n    }\n\n    .bold {\n      font-weight: bold;\n    }\n\n    .flag {\n      width: 16px;\n      height: 12px;\n      display: none;\n    }\n  </style>\n  <script>\n    document.addEventListener(\"DOMContentLoaded\", () => {\n      const dayOffset = [1, 1, 1, 1, 1, 3, 2]; // Next weekday logic\n      const shipDate = new Date();\n      shipDate.setDate(shipDate.getDate() + dayOffset[shipDate.getDay()]);\n      document.getElementById(\"date\").textContent = shipDate.toLocaleDateString(\"en-US\", { weekday: 'short', month: 'short', day: 'numeric' });\n\n      fetch('https://get.geojs.io/v1/ip/geo.json')\n        .then(res => res.json())\n        .then(data => {\n          const code = data.country_code?.toUpperCase();\n          if (!code) throw new Error(\"No country code\");\n\n          const flag = document.getElementById(\"flag\");\n          flag.src = `https://flagcdn.com/w40/${code.toLowerCase()}.png`;\n          flag.alt = `${code} Flag`;\n          flag.style.display = \"inline\";\n\n          document.getElementById(\"country\").innerHTML = `Fast <span class=\"bold\">${code}</span> Shipping`;\n        })\n        .catch(() => {\n          document.getElementById(\"country\").textContent = \"Fast Worldwide Shipping\";\n        });\n    });\n  </script>\n</head>\n<body>\n  <div class=\"shipping-bar\">\n    <div class=\"left\">\n      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"12\" height=\"13\" viewBox=\"0 0 12 13\" fill=\"none\">\n        <circle cx=\"6\" cy=\"6.5\" r=\"6\" fill=\"#4CAF37\"/>\n      </svg>\n      <span>Ships by <span id=\"date\" class=\"bold\"></span></span>\n    </div>\n    <div class=\"right\">\n      <img id=\"flag\" class=\"flag\" src=\"\" alt=\"\">\n      <span id=\"country\">Loading...</span>\n    </div>\n  </div>\n</body>\n</html>"
          }
        },
        "custom_9fhiNJ": {
          "type": "custom",
          "settings": {
            "code": "{%- comment -%}\n  Revolt – Payment Badges clean & centered\n  Usage: {% render 'revolt-payment-badges' %}\n{%- endcomment -%}\n\n<style>\n  .revolt-payment-badges{ \n    margin-top:.5rem; \n    margin-bottom:.25rem;\n  }\n  .revolt-payment-badges__list{\n    display:flex; \n    align-items:center; \n    justify-content:center;  /* centreren */\n    gap:.6rem;               /* compactere spacing */\n    flex-wrap:wrap;\n  }\n  .revolt-payment-badges__item{\n    display:inline-flex; \n    align-items:center; \n    justify-content:center;\n    line-height:0;\n    border:none !important;\n    background:none !important;\n    box-shadow:none !important;\n    padding:0 !important;\n    border-radius:0 !important;\n  }\n  .revolt-payment-badges__item > *{\n    border:none !important;\n    background:none !important;\n    box-shadow:none !important;\n    padding:0 !important;\n    border-radius:0 !important;\n  }\n  .revolt-payment-badges__item svg{\n    height:20px;   /* goede balans mobiel */\n    width:auto;\n    display:block;\n    fill:currentColor !important;\n    shape-rendering:geometricPrecision;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n  }\n  @media (min-width:768px){\n    .revolt-payment-badges__item svg{ height:22px; }\n  }\n</style>\n\n{%- assign revolt_methods = \"american_express,visa,master,apple_pay,google_pay,shopify_pay,paypal\" | split: \",\" -%}\n\n<div class=\"revolt-payment-badges\" role=\"group\" aria-label=\"Supported payment methods\">\n  <div class=\"revolt-payment-badges__list\">\n    {%- for m in revolt_methods -%}\n      <span class=\"revolt-payment-badges__item\" aria-label=\"{{ m | replace: '_',' ' | capitalize }}\" title=\"{{ m | replace: '_',' ' | capitalize }}\">\n        {{ m | payment_type_svg_tag }}\n      </span>\n    {%- endfor -%}\n  </div>\n</div>"
          }
        },
