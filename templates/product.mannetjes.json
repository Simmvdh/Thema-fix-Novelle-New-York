        "custom_k6bQKc": {
          "type": "custom",
          "disabled": true,
          "settings": {
            "code": "<style>\n  .low-stock {\n    font-family: inherit;\n    display: flex;           /* flexbox ipv inline-flex */\n    align-items: center;     /* zorgt dat bolletje + tekst op 1 lijn staan */\n    gap: 8px;\n    justify-content: flex-start; /* links uitlijnen */\n  }\n\n  .pulse-dot {\n    position: relative;\n    width: 10px;\n    height: 10px;\n    border-radius: 50%;\n    background: #e60000;\n    flex-shrink: 0;\n\n    /* hoogte verschuifbaar */\n    --dot-offset: 0px;\n    transform: translateY(var(--dot-offset));\n  }\n\n  .pulse-dot::after {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    border-radius: 50%;\n    box-shadow: 0 0 0 0 rgba(230, 0, 0, 0.45);\n    animation: pulse-ring 1.6s ease-out infinite;\n  }\n\n  @keyframes pulse-ring {\n    0%   { box-shadow: 0 0 0 0 rgba(230,0,0,.45); }\n    70%  { box-shadow: 0 0 0 5px rgba(230,0,0,0); }\n    100% { box-shadow: 0 0 0 0 rgba(230,0,0,0); }\n  }\n\n  @media (prefers-reduced-motion: reduce){\n    .pulse-dot::after { animation: none; }\n  }\n</style>\n\n<div class=\"low-stock\">\n  <!-- pas --dot-offset aan om bolletje hoger/lager te zetten -->\n  <span class=\"pulse-dot\" style=\"--dot-offset:-2px;\" aria-hidden=\"true\"></span>\n  <span id=\"stock-text\">Only 9 left in stock!</span>\n</div>\n\n<script>\n  (function(){\n    // random getal tussen 2 en 9\n    var n = Math.floor(Math.random() * 8) + 2;\n    document.getElementById(\"stock-text\").textContent = \"Only \" + n + \" left in stock!\";\n  })();\n</script>"
          }
